rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Invoices collection - TEMPORARY: Allow unauthenticated access for testing
    match /invoices/{invoiceId} {
      // TESTING: Allow all reads/writes (CHANGE THIS BEFORE PRODUCTION!)
      allow read, write, create, delete: if true;
      
      // TODO: Enable proper authentication before launch:
      // allow read: if isAuthenticated();
      // allow write: if isAuthenticated() && 
      //                 (request.resource.data.userId == request.auth.uid ||
      //                  resource.data.userId == request.auth.uid);
      // allow create: if isAuthenticated() && 
      //                  request.resource.data.userId == request.auth.uid;
      // allow delete: if isAuthenticated() && 
      //                  resource.data.userId == request.auth.uid;
    }
    
    // Clients collection - TEMPORARY: Allow unauthenticated access for testing
    match /clients/{clientId} {
      // TESTING: Allow all reads/writes (CHANGE THIS BEFORE PRODUCTION!)
      allow read, write, create, delete: if true;
      
      // TODO: Enable proper authentication before launch
    }
    
    // Estimates collection - TEMPORARY: Allow unauthenticated access for testing
    match /estimates/{estimateId} {
      allow read, write, create, delete: if true;
    }
    
    // Price Book Items - TEMPORARY: Allow unauthenticated access for testing
    match /priceBookItems/{itemId} {
      allow read, write, create, delete: if true;
    }
    
    // Settings/Profile - TEMPORARY: Allow unauthenticated access for testing
    match /settings/{userId} {
      allow read, write: if true;
    }
    
    // App Config - allow public read for app configuration
    match /app_config/{document} {
      allow read: if true; // Public read for config (safe - contains only app settings)
      allow write: if false; // Only admins can write (must be done via Firebase Console)
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
