{
  "name": "app-functions",
  "description": "Firebase Cloud Functions for app operations",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "echo 'No build needed for JavaScript'",
    "build:watch": "echo 'No build needed for JavaScript'",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@apple/app-store-server-library": "^1.6.0",
    "@sendgrid/mail": "^8.1.6",
    "dotenv": "^16.3.1",
    "ebay-oauth-nodejs-client": "^1.2.2",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.4.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^4.9.0"
  },
  "private": true
}
